module alu(
    input  [7:0]     a, b,
    input  [2:0]     op,
    output reg [7:0] result,
    output           zero,
    output reg       carry,
    output reg       overflow
);
    always@(*) begin
    result = 8'b0;
    carry = 0; overflow = 0;
        if(op == 0) begin
      {carry, result} = a+b;
      overflow = a[7]&b[7]&(~result[7]) | (~a[7])&(~b[7])&result[7];
        end
    else if(op == 1) begin
      {carry,result[7:0]} = {1'b0,a[7:0]} - {1'b0,b[7:0]};         
    overflow = (a[7] & ~b[7] & ~result[7]) | (~a[7] & b[7] & result[7]);
    end
      else if (op == 2)
        result = a&b;
    else if(op == 3)
      result = a | b;
    else if(op == 4)
      result = a^b;
    else if (op == 5)begin
      result = {a[6:0],1'b0};
      carry = a[7];
    end
    else if (op == 6)begin
      result = {1'b0,a[7:1]};
      carry = a[0];
    end
  end
  assign zero = (result == 8'b0)? 1: 0;
      
endmodule
